# JWT signing secret — required. Generate with: openssl rand -hex 32
# Rotating this value invalidates all existing tokens immediately.
AUTH_SECRET=<run: openssl rand -hex 32>

# JWT token lifetime in seconds (default: 604800 = 7 days).
JWT_TTL_SECONDS=604800

# LLM API keys — set the one matching `provider` in configs/default.yaml
OPENAI_API_KEY=<your_openai_api_key_here>
OPENROUTER_API_KEY=<your_openrouter_api_key_here>

# Postgres connection string (pgvector/pgvector:pg16 image or compatible)
# From source / host-side dev: use localhost and the mapped port.
# Via docker compose: the backend container overrides this to use the db service
# name — you do not need to change this value when running via compose.
DATABASE_URL=postgresql://cinepal:cinepal@localhost:4321/cinepal

# Image version tag to pull when using docker compose.
# Defaults to "latest". Pin to a specific release for reproducible deployments,
# e.g. CINEPAL_VERSION=v1.2.0
CINEPAL_VERSION=latest

# Logging level (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=INFO

# TMDB v3 API key — ONLY needed when running the snapshot script in Colab
# (notebooks/embed_in_colab.ipynb → db/ingestion/tmdb_snapshot.py). Local
# ingest never calls TMDB.
TMDB_API_KEY=<your_tmdb_api_key>

# Hugging Face token — ONLY required when the artifacts repo pinned in
# configs/<name>.yaml (ingestion.hf_repo) is private. Leave unset for the
# default public repo.
HF_TOKEN=<your_hf_token>
